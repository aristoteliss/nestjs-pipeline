{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Users API",
      "skipFiles": ["<node_internals>/**"],
      "runtimeArgs": ["--nolazy", "-r", "tsx/cjs"],
      "program": "${workspaceFolder}/ddd/users-api/src/main.ts",
      "cwd": "${workspaceFolder}/ddd/users-api",
      "env": {
        "TSX_TSCONFIG_PATH": "${workspaceFolder}/ddd/users-api/tsconfig.json"
      },
      "sourceMaps": true,
      "console": "integratedTerminal",
      "outputCapture": "std"
    }
  ]
}
