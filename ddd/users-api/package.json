{
  "name": "@nestjs-pipeline/ddd-users-api",
  "version": "0.0.4",
  "private": true,
  "description": "Sample NestJS app demonstrating @nestjs-pipeline/core usage",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:fastify": "ADAPTER=fastify ts-node -r tsconfig-paths/register src/main.ts",
    "build:deps": "pnpm --filter \"@nestjs-pipeline/ddd-users-api^...\" run build",
    "prebuild": "pnpm run build:deps",
    "build": "tsc -p tsconfig.json",
    "predev": "pnpm run build",
    "dev": "node --nolazy -r tsx/cjs dist/main.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "rebuild": "pnpm run clean && pnpm run build",
    "db:migrate": "tsx src/persistence/migrate.ts",
    "db:revert": "tsx src/persistence/revert.ts",
    "start:prod": "node dist/main",
    "start:prod:fastify": "ADAPTER=fastify node dist/main"
  },
  "dependencies": {
    "@casl/ability": "^7.0.0",
    "@fastify/secure-session": "^8.3.0",
    "@libsql/client": "^0.17.3",
    "@mikro-orm/core": "^7.1.3",
    "@mikro-orm/libsql": "^7.1.3",
    "@mikro-orm/migrations": "^7.1.3",
    "@mikro-orm/nestjs": "^7.0.2",
    "@mikro-orm/postgresql": "7.1.3",
    "@mikro-orm/sqlite": "^7.1.3",
    "@nestjs-pipeline/casl": "workspace:*",
    "@nestjs-pipeline/core": "workspace:*",
    "@nestjs-pipeline/correlation": "workspace:*",
    "@nestjs-pipeline/ddd-core": "workspace:*",
    "@nestjs-pipeline/opentelemetry": "workspace:*",
    "@nestjs-pipeline/zod": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.64.0",
    "@opentelemetry/instrumentation-pg": "^0.70.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "bullmq": "^5.77.6",
    "jose": "^6.2.3",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.21.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}