{
  "name": "@nestjs-pipeline/ddd-users-api",
  "version": "0.0.1",
  "private": true,
  "description": "Sample NestJS app demonstrating @nestjs-pipeline/core usage",
  "scripts": {
    "start": "ts-node src/main.ts",
    "start:fastify": "ADAPTER=fastify ts-node src/main.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "rebuild": "pnpm run clean && pnpm run build",
    "start:prod": "node dist/main",
    "start:prod:fastify": "ADAPTER=fastify node dist/main"
  },
  "dependencies": {
    "@nestjs-pipeline/core": "workspace:*",
    "@nestjs-pipeline/correlation": "workspace:*",
    "@nestjs-pipeline/ddd-core": "workspace:*",
    "@nestjs-pipeline/opentelemetry": "workspace:*",
    "@nestjs-pipeline/zod": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-fastify": "^11.1.17",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.59.0",
    "@opentelemetry/instrumentation-pg": "^0.65.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@libsql/client": "^0.17.2",
    "bullmq": "^5.71.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
