{
  "name": "@nestjs-pipeline/ddd-users-api",
  "version": "0.0.2",
  "private": true,
  "description": "Sample NestJS app demonstrating @nestjs-pipeline/core usage",
  "scripts": {
    "start": "ts-node src/main.ts",
    "start:fastify": "ADAPTER=fastify ts-node src/main.ts",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "rebuild": "pnpm run clean && pnpm run build",
    "db:migrate": "tsx src/persistence/migrate.ts",
    "db:seed": "tsx src/persistence/seed.ts",
    "start:prod": "node dist/main",
    "start:prod:fastify": "ADAPTER=fastify node dist/main"
  },
  "dependencies": {
    "@casl/ability": "^6.0.0",
    "@fastify/secure-session": "^8.3.0",
    "@libsql/client": "^0.17.2",
    "@nestjs-pipeline/casl": "workspace:*",
    "@nestjs-pipeline/core": "workspace:*",
    "@nestjs-pipeline/correlation": "workspace:*",
    "@nestjs-pipeline/ddd-core": "workspace:*",
    "@nestjs-pipeline/opentelemetry": "workspace:*",
    "@nestjs-pipeline/zod": "workspace:*",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-fastify": "^11.1.18",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.214.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.60.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "bullmq": "^5.73.3",
    "jose": "^6.2.2",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
