{
  "name": "nestjs-pipeline-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "NestJS CQRS pipeline behavior monorepo",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "rebuild": "pnpm -r clean && pnpm -r build",
    "publish:all": "pnpm -r publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@nestjs/core",
      "protobufjs"
    ]
  }
}
