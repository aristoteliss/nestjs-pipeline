{
  "name": "nestjs-pipeline-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "NestJS CQRS pipeline behavior monorepo",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "rebuild": "pnpm -r clean && pnpm -r build",
    "publish:all": "pnpm -r publish --access public"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@nestjs/core",
      "protobufjs"
    ]
  }
}